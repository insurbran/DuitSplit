# Google Gemini API key (used by the backend for OCR + parsing).
# Get one at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-gemini-api-key-here

# Backend database path (relative to the backend working dir).
DB_PATH=data/duitsplit.db

# Root data directory for the Bronze (images) and Silver (text) ETL layers.
DATA_DIR=data

# Incomplete sessions older than this many hours are swept automatically.
# Set to 0 to disable the sweep. The sweeper runs every SWEEP_INTERVAL_SECONDS.
SESSION_TTL_HOURS=24
SWEEP_INTERVAL_SECONDS=3600

# Frontend → backend URL. For local (non-Docker) dev use http://localhost:8001
BACKEND_URL=http://backend:8001
